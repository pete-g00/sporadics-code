# -------------------------------------------------------------------------------------------------
# Essentials in $N_G(W)$ are $X_i^\Sut(S)$, $Y^S$ and $Q$.
# -------------------------------------------------------------------------------------------------

NGW := PcGroupCode(
, 30233088);

S := SylowSubgroup(NGW, 3);
W := PCore(NGW, 3);

C := CharacteristicSubgroups(S);;
V := First(C, A -> Size(A) = 3^6 and IsElementaryAbelian(A));

q := NaturalHomomorphismByNormalSubgroup(S, W); 
C := SubgroupsSolvableGroup(Image(q)); # Since $W$ is normal in $N_G(W)$, all essentials contain $W$

C := Filtered(C, A -> Size(A) >= 3 and Index(Image(q), A) >= 3);
C := List(C, A -> PreImage(q,A));
C := Filtered(C, A -> PCore(Normalizer(NGW,A),3) = A); # $N_G(W)$-radical, excluding $W$ and $S$

Length(C); # should be 5 (3 $S$-classes for $X_i$)

ClosureGroup(W,V) in C; # $Q = \langle W, V \rangle$

Number(C, A -> Index(Normalizer(S,A), A)=3); # should be 5
Number(C, A -> Index(S,A) = 3^2); # should be 4 (must be the preimage of the four non-central subgroups of $S/W$ since index 3 in the normalizer)

# -------------------------------------------------------------------------------------------------
# Essentials in $N_G(W)$ are $Q$ and $R$.
# -------------------------------------------------------------------------------------------------
NGV := Group((1,27,43,105,96,63,89,53,104,60,8,54)(2,67,25,44)(3,72,24,17)(4,7,90,92,65,74,73,99,98,47,13,31)(5,33,11,48,81,71,100,6,66,10,12,85)(9,101,55,61,51,52)(14,84)(15,106,68,49)(16,23,41,42)(18,20,76,45,75,21,19,83,46,94,34,57)(22,86,87,95)(26,36,37,62,58,38,40,28,97,93,39,59)(29,30,32,91,70,82)(35,56,80)(50,69,88,64)(77,79)(102,108,103,107), 
(1,43,44,25)(2,60,67,78,42,63,103,79,108,27,16,77)(3,45,5,6,87,83,66,48,49,57,81,85)(4,31,13,14,98,92,73,64,65,99,90,69)(7,84)(8,41,23,96)(9,10,76,26,51,33,34,58,55,71,19,97)(11,61,62,72)(12,52,59,95)(15,100,101,28)(17,18,68,46,86,75)(20,24,39,36,21,22,40,93,94,106,37,38)(29,30,70,82,32,91)(35,80,56)(47,88,74,50)(53,54)(89,102,107,104), 
(7,40)(8,82)(10,92)(11,27)(12,63)(13,61)(16,34)(18,25)(19,103)(20,84)(21,88)(22,56)(23,75)(24,35)(30,43)(31,33)(36,105)(37,74)(38,54)(39,47)(45,57)(46,107)(50,94)(52,90)(53,93)(60,100)(67,76)(71,99)(73,101)(80,106)(89,91));

S := SylowSubgroup(NGV, 3);
V := PCore(NGV, 3);

C := CharacteristicSubgroups(S);;
W := First(C, A -> Size(A) = 3^7 and Exponent(A)=3);

q := NaturalHomomorphismByNormalSubgroup(S, V); 
C := SubgroupsSolvableGroup(Image(q));

C := Filtered(C, A -> Size(A) >= 3 and Index(Image(q), A) >= 3);
C := List(C, A -> PreImage(q,A));
C := Filtered(C, A -> PCore(Normalizer(NGV,A),3) = A); # $N_G(V)$-radical, excluding $V$ and $S$

Length(C); # should be 2
Number(C, A -> Index(S,A) = 3); # should be 2

ClosureGroup(W,V) in C; # $Q = \langle W, V\rangle$
U := UpperCentralSeries(S);
Z2S := U[5];
R := Centralizer(S, Z2S);

R in C; # $R = C_S(Z_2(S))$

# -------------------------------------------------------------------------------------------------
NGQ := Normalizer(G, Q);
f := IsomorphismPcGroup(NGQ);;

NGQ := Image(f, NGQ);
S := Image(f, S);
Q := Image(f, Q);

AutGQ := Automizer(NGQ,Q);
AutSQ := Automizer(S,Q);
InnQ := Automizer(Q,Q);

AutQ := AutomorphismGroupPGroup(Q);;
AutQ := PcGroupAutPGroup(AutQ);

AutGQ := PcSubAutPGroup(AutQ, AutGQ);
AutSQ := PcSubAutPGroup(AutQ, AutSQ);
InnQ := PcSubAutPGroup(AutQ, InnQ);

q := NaturalHomomorphismByNormalSubgroup(AutQ, InnQ);

OutQ := Image(q);
OutGQ := Image(q, AutGQ);
OutSQ := Image(q, AutSQ);

CoQ := ComplementClassesRepresentatives(OutQ, PCore(OutQ,3));;
Length(CoQ); # should be 1
StructureDescription(CoQ[1]); # should be $2 \times \times \Sym(4)$

N1 := Normalizer(OutGQ, OutSQ);
N2 := Normalizer(OutQ, N1);
N := Normalizer(OutQ, OutSQ);

IsSubset(N, N2); # $N2 \leq N$

Q := PreImage(f, Q);

# -------------------------------------------------------------------------------------------------
# $\Aut_F(S)$ determines $\Out_F(X)$ in $\O^+_8(3) : \Sym(4)$ 
# -------------------------------------------------------------------------------------------------
NGX := Normalizer(G, Ex);
f := IsomorphismPcGroup(NGX);;
Q := Image(f,Q);

NGX := Image(f, NGX);
Ex := Image(f, Ex);

AutGX := Automizer(NGX,Ex);
AutSX := Automizer(Q,Ex);
InnX := Automizer(Ex,Ex);

AutX := AutomorphismGroupPGroup(Ex);;
AutX := PcGroupAutPGroup(AutX);

AutGX := PcSubAutPGroup(AutX, AutGX);
AutSX := PcSubAutPGroup(AutX, AutSX);
InnX := PcSubAutPGroup(AutX, InnX);

q := NaturalHomomorphismByNormalSubgroup(AutX, InnX);

OutX := Image(q);
OutGX := Image(q, AutGX);
OutSX := Image(q, AutSX);

CoX := ComplementClassesRepresentatives(OutX, PCore(OutX,3));;
Length(CoX); # should be 1
StructureDescription(CoX[1]); # should be $\Dih(8) \times \GL_2(3)$

N1 := Normalizer(OutGX, OutSX);
N2 := Normalizer(OutX, N1);
N := Normalizer(OutX, OutSX);

IsSubset(N, N2); # $N2 \leq N$

OnQuotient := function(q)
    return function(t, x)
        return Image(q, PreImagesRepresentative(q,t)^x);
    end;
end;

# Computes C_G(A/U)
StepCentralizer := function(G, A, U)
    local q;
    q := NaturalHomomorphismByNormalSubgroup(G,U);
    return Kernel(ActionHomomorphism(G, Image(q,A), OnQuotient(q)));
end;

S := PcGroupCode(
, 3^20);

M := MaximalSubgroups(S);;
M := Filtered(M, A -> Exponent(A) = 9);;
W := First(CharacteristicSubgroups(S), A -> Rank(A) = 12 and Exponent(A) = 3 and Size(A) = 3^13);

P := First(M, A -> Intersection(A,W) = W);
R := First(M, A -> Size(Center(A)) = 9);

q := NaturalHomomorphismByNormalSubgroup(S,W);;
N := NormalSubgroups(Image(q));;
Q := First(N, A -> Size(A) = 3^5 and IsElementaryAbelian(A));
Q := PreImage(q, Q);

# -------------------------------------------------------------------------------------------------
# $Z_3(S) = Z_2(P) = Z_2(R)$
# -------------------------------------------------------------------------------------------------
US := UpperCentralSeries(S);;
UP := UpperCentralSeries(P);;
UR := UpperCentralSeries(R);;

UP[5] = UR[6]; # should be true
US[7] = UR[6]; # should be true

# -------------------------------------------------------------------------------------------------
# $U = C_Q(Z_2(Q)) = C_R(Z_3(R)/Z(R))$
# -------------------------------------------------------------------------------------------------
U := Intersection(Q, R);

UQ := UpperCentralSeries(Q);;
Z2Q := UQ[4];

U = Centralizer(Q, Z2Q); # should be true

U = StepCentralizer(R, UR[5], UR[7]); # should be true

S := PcGroupCode(
, 3^20);

M := MaximalSubgroups(S);;
M := Filtered(M, A -> Exponent(A) = 9);;

P := First(M, A -> Center(A) = Center(S));
R := First(M, A -> Center(A) <> Center(S));

# -------------------------------------------------------------------------------------------------
# $O^{3'}(\Out_F(P)) \cong \SL_2(3)$
# -------------------------------------------------------------------------------------------------
UP := UpperCentralSeries(P);;
US := UpperCentralSeries(S);;

UP[5] = US[7]; # Z_2(P) = Z_3(S)
UP[4] = US[6]; # Z_3(P) = Z_4(S)

CP := Centralizer(P, UP[4]);
IsSubset(FrattiniSubgroup(P), CP); # C_P(Z_3(P)) \leq \Phi(P)

T := Centralizer(S, US[7]);
Center(T) = UP[5]; # Z(T) = Z_2(P)

# -------------------------------------------------------------------------------------------------
# $O^{3'}(\Out_F(R)) \cong \SL_2(3)$
# -------------------------------------------------------------------------------------------------
UR := UpperCentralSeries(R);;

Index(R, FrattiniSubgroup(R)); # should be 3^4
FrattiniSubgroup(R) = UR[2]; # \Phi(R) = Z_6(R)

Index(R, T); # should be 3^2
Index(T, FrattiniSubgroup(R)); # should be 3^2

IsSubset(FrattiniSubgroup(R), CommutatorSubgroup(S,T)); # [S, T] \leq \Phi(R)

UR[6] = US[7]; # Z_2(R) = Z_3(S)
UR[5] = US[6]; # Z_3(R) = Z_4(S)
UR[4] = US[5]; # Z_4(R) = Z_5(S)

Centralizer(S, UR[4]) = UR[4]; # Z_4(R) is self-centralizing

# -------------------------------------------------------------------------------------------------
# $O^{3'}(\Out_F(X)) \cong \SL_2(9)$
# -------------------------------------------------------------------------------------------------
W := First(CharacteristicSubgroups(S), A -> Exponent(A) = 3 and Size(A) = 3^13 and Rank(A) = 12);

q := NaturalHomomorphismByNormalSubgroup(S, W);;

Ex := SubgroupsSolvableGroup(Image(q));;
Ex := Filtered(Ex, A -> Size(A) = 3^2);;
Ex := List(Ex, A -> PreImage(q, A));;
Ex := Filtered(Ex, A -> Normalizer(S, Normalizer(S,A)) = P);;
LX := List(Ex, A -> LowerCentralSeries(A)[3]);;
I := Filtered([1..Length(Ex)], i -> CommutatorSubgroup(Centralizer(Ex[i], LX[i]), Normalizer(S, Ex[i])) = FrattiniSubgroup(Ex[i]));
Ex := Ex{I};
Ex := Filtered(Ex, A -> ForAll(MaximalSubgroups(A), X -> FrattiniSubgroup(X) = FrattiniSubgroup(A)));

UX := UpperCentralSeries(Ex[1]);
C := Centralizer(S, UX[3]);
Index(Ex[1], C); # should be 3^4

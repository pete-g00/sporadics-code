S := PcGroupCode(
, 3^20);

# Subgroups of $S$ that are known not to be essential in M, but cannot be checked using the radical/lift method

# 3^17 step.

# (1) We have $\Out_S(E)$ eab order $3^2$, meaning that $O^{3'}(\Out_F(E))$ is isomorphic to one of: $\Alt(6)$, $\SL_2(9)$ or $\Mt_{11}$
# (2) We have $Z_2(E)$ eab order $3^7$ and self-centralizing
# (3) Since $[N_S(E), Z(E)] = 1$, $O^{3'}(\Out_F(E))$ acts faithfully on $Z_2(E)/Z(E)$ of order $3^4$, i.e. natural $\Alt(6)$-module
# (4) 
A1 := Group([ S.18*S.20^2, S.19*S.20^2, S.20, S.20, S.20, S.2, S.3*S.4^2*S.5*S.6*S.7*S.8*S.9*S.11*S.12^2*S.13^2*S.15*S.16*S.17^2, S.3*S.4^2*S.5^2*S.8*S.9^2*S.11^2*S.12^2*S.14^2*S.16^2, S.3^2*S.4*S.5^2*S.6^2*S.8^2*S.9^2*S.12*S.13*S.14*S.15^2*S.16, S.10^2*S.13^2*S.14*S.17^2, S.17, S.7^2*S.8^2*S.13*S.14*S.16*S.17, S.16^2*S.17^2, S.8^2*S.13*S.15*S.16^2*S.17, S.15^2*S.16*S.17^2, S.13^2*S.14, S.14 ]);

# 3^19 step

# (1) $A := \langle \Phi(E), Z_4(E) \rangle = [N_S(E), E]$, meaning that $O^{3'}(\Out_F(E))$ acts trivially on $E/A$. 
# (2) $A/\Phi(E)$ has order $3$, so $O^{3'}(\Out_F(E))$ acts trivially on $A/\Phi(E)$
# Conclude that: $O^{3'}\Out_F(E)) = \Out_S(E)$, i.e. $E$ is not essential.
A2 := Group([ S.1, S.6*S.10*S.13*S.14^2*S.17*S.18*S.19^2, S.4^2*S.6*S.8^2*S.13*S.16*S.17*S.19, S.5*S.6^2*S.13*S.14^2*S.17*S.19, S.11*S.12^2*S.13*S.14*S.18^2*S.19^2,
      S.3^2*S.4*S.5^2*S.6^2*S.13*S.14*S.15^2*S.17*S.18*S.19^2, S.9*S.11*S.12*S.13*S.15^2*S.16^2*S.17^2*S.18^2*S.19^2, S.17*S.18^2*S.19^2,
      S.7^2*S.8^2*S.13*S.14*S.16*S.17*S.18^2*S.19, S.16^2*S.17^2, S.8^2*S.13*S.15*S.16^2*S.17*S.18, S.15^2*S.16*S.17^2*S.18*S.19, S.13^2*S.14*S.18^2,
      S.14*S.19, S.19^2, S.18*S.19^2 ]);

# (1) $A := \langle \Phi(E), Z_4(E) \rangle = [N_S(E), E]$, meaning that $O^{3'}(\Out_F(E))$ acts trivially on $E/A$. 
# (2) $A/\Phi(E)$ has order $3$, so $O^{3'}(\Out_F(E))$ acts trivially on $A/\Phi(E)$
# Conclude that: $O^{3'}\Out_F(E)) = \Out_S(E)$, i.e. $E$ is not essential.
A3 := Group([ S.1, S.6*S.17*S.18^2*S.19^2, S.4^2*S.6*S.8^2*S.13*S.16*S.17*S.19, S.5*S.6^2*S.13*S.14^2*S.17*S.19,
      S.11*S.12^2*S.13*S.14*S.17*S.18*S.19, S.3^2*S.4*S.5^2*S.6^2*S.13*S.14*S.15^2*S.17*S.18*S.19^2, S.9*S.11*S.12*S.13*S.15^2*S.16^2*S.17^2*S.18^2*S.19^2,
      S.10^2*S.13^2*S.14*S.18, S.7^2*S.8^2*S.13*S.14*S.16*S.17*S.18^2*S.19, S.16^2*S.17^2, S.8^2*S.13*S.15*S.16^2*S.17*S.18, S.15^2*S.16*S.17^2*S.18*S.19,
      S.13^2*S.14*S.18^2, S.14*S.19, S.19^2, S.18*S.19^2 ]);


# 3^20 step

# (1) We have $\Phi(E) \leq C_S(\Phi(E))$ is such that $[N_S(E), E] \leq C_S(\Phi(E))$, so. $O^{3'}(\Out_F(E))$ centralizes $E/C_S(\Phi(E))$
# (2) We have $[C_S(\Phi(E)) : Z_3(E)] = 3$, so $O^{3'}(\Out_F(E))$ centralizes $C_S(\Phi(E))/Z_2(E)$
# (3) Since $[N_S(E), Z_2(E)] \leq \Phi(E)$, we deduce that $O^{3'}(\Out_F(E))$ centralizes $Z_2(E)/\Phi(E)$
# Conclude that: $O^{3'}(\Out_F(E)) = \Out_S(E)$, i.e. $E$ is not essential
A4 := Group([ S.6*S.7*S.8*S.13^2*S.14^2*S.18^2*S.19^2, S.4^2*S.6*S.7*S.14^2*S.18*S.19^2*S.20^2, S.5*S.6^2*S.13*S.14^2*S.17*S.18*S.19, S.11*S.12^2*S.13*S.14*S.19^2*S.20,
  S.10^2*S.13^2*S.14*S.17^2*S.18*S.20, S.17*S.19^2*S.20, S.8^2*S.13*S.15*S.16^2*S.17*S.19*S.20^2, S.15^2*S.16*S.17^2*S.18^2*S.20,
  S.13^2*S.14*S.18^2*S.19*S.20^2, S.14*S.18*S.19*S.20^2, S.19*S.20^2, S.18^2*S.19^2*S.20^2 ]);

# (1) We have $[N_S(E), E] \leq Z_2(E)$, meaning that $O^{3'}(\Out_F(E))$ acts trivially on $E/Z_2(E)$
# (2) We have $[N_S(E), Z_2(E)] \leq \Phi(E)$, meaning that $O^{3'}(\Out_F(E))$ acts trivially on $Z_2(E)/\Phi(E)$
# Conclude that: $O^{3'}\Out_F(E)) = \Out_S(E)$, i.e. $E$ is not essential.
A5 := Group([ S.1, S.6*S.10*S.13*S.14^2*S.18^2*S.19*S.20^2, S.4^2*S.6*S.8^2*S.13*S.16*S.17*S.20, S.3^2*S.4*S.5^2*S.6^2*S.13*S.14*S.15^2*S.17*S.18*S.19^2*S.20,
      S.9*S.11*S.12*S.13*S.15^2*S.16^2*S.17^2*S.18*S.20^2, S.7^2*S.8^2*S.13*S.14*S.16*S.17*S.18^2*S.19*S.20^2, S.16^2*S.17^2*S.18^2*S.19^2*S.20^2,
      S.8^2*S.13*S.15*S.16^2*S.17*S.19*S.20^2, S.15^2*S.16*S.17^2*S.18^2*S.20, S.13^2*S.14*S.18^2*S.19*S.20^2, S.14*S.18*S.19*S.20^2, S.19*S.20^2,
      S.18^2*S.19^2*S.20^2 ]);

# (1) We have $[N_S(E), E] = Z_2(E)$, meaning that $O^{3'}(\Out_F(E))$ acts trivially on $E/Z_2(E)$
# (2) $Z_2(E)/\Phi(E)$ has order $3$, so $O^{3'}(\Out_F(E))$ acts trivially on $Z_2(E)/\Phi(E)$
# Conclude that: $O^{3'}\Out_F(E)) = \Out_S(E)$, i.e. $E$ is not essential.
A6 := Group([ S.1*S.20, S.6*S.10*S.13*S.14^2*S.18^2*S.19*S.20^2, S.4^2*S.6*S.8^2*S.13*S.16*S.17*S.20,
      S.3^2*S.4*S.5^2*S.6^2*S.13*S.14*S.15^2*S.17*S.18*S.19^2*S.20, S.9*S.11*S.12*S.13*S.15^2*S.16^2*S.17^2*S.18*S.20^2,
      S.7^2*S.8^2*S.13*S.14*S.16*S.17*S.18^2*S.19*S.20^2, S.16^2*S.17^2*S.18^2*S.19^2*S.20^2, S.8^2*S.13*S.15*S.16^2*S.17*S.19*S.20^2,
      S.15^2*S.16*S.17^2*S.18^2*S.20, S.13^2*S.14*S.18^2*S.19*S.20^2, S.14*S.18*S.19*S.20^2, S.19*S.20^2, S.18^2*S.19^2*S.20^2 ]);

